# Copy to .env and fill in. All keys are EXPO_PUBLIC_* so they're available in the app.
# The app runs fully local-first WITHOUT any of these — they only enable extra features.

# Supabase backend (accounts + cross-device sync). Find these in your Supabase
# project: Settings → API. The anon key is safe to ship in a client app; row-level
# security (see supabase/migrations) is what protects the data.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI follow-up drafts in development. Leave blank to use the built-in templates.
# In production, set EXPO_PUBLIC_DRAFTS_ENDPOINT to a backend proxy instead so no
# API key ships in the app bundle.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_DRAFTS_ENDPOINT=
