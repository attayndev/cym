{
  "$schema": "node_modules/wrangler/config-schema.json",
  // The logged-in web app (the RN web export) on the app subdomain.
  // The marketing site owns the root domain — see wrangler.jsonc.
  "name": "callyourmom-app",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [{ "pattern": "app.getcym.app", "custom_domain": true }]
}
